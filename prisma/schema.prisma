generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model SkillAnalysisRecord {
  id             String   @id @default(cuid())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  sourceFileName String   @default("")
  questionId     String
  questionText   String?
  analysisMode   String
  providerId     String?
  modelId        String?
  ipAddress      String?
  userAgent      String?
  rawAnswers     Json
  userInput      String
  generatedSkill String?
  status         String   @default("pending")
  lastError      String?

  @@unique([sourceFileName, questionId, analysisMode], name: "source_question_analysis_mode")
}