generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ExportDownloadLog {
  id               String   @id @default(cuid())
  createdAt        DateTime @default(now())
  analysisMode     String
  exportedFileName String
  sourceFileName   String?
  ipAddress        String?
  userAgent        String?
  rawAnswers       Json
  generatedSkills  Json
}